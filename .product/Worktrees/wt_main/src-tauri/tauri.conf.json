{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "StratAtlas",
  "version": "0.1.4",
  "identifier": "com.stratatlas.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev --host 0.0.0.0 --port 1420",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "StratAtlas",
        "width": 1360,
        "height": 860,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi",
      "nsis"
    ],
    "windows": {
      "allowDowngrades": true,
      "wix": {
        "upgradeCode": "A3D5A1D8-5A7B-4C53-8CC4-1D2C1F80D0AF",
        "language": "en-US"
      },
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "resources": [
      "../scripts/windows-installer-maintenance.ps1",
      "../docs/INSTALLER_LIFECYCLE.md"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
